# ─────────────────────────────────────────────────────────────
# Supabase — backs the contact form.
# Get these values from the Supabase dashboard:
#   Project Settings → API
# ─────────────────────────────────────────────────────────────

# Project URL — looks like https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Anon / publishable key — safe to ship to the browser.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role / secret key — server-only.  Bypasses RLS.  Never commit,
# never expose to the browser, never inline into a Client Component.
# Put the REAL value in .env.local (gitignored), NOT here.
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────────────────
# Resend — branded email notification when the contact form is
# submitted.  Sign up at resend.com (use hellopromisecity@gmail.com
# so test sends reach that inbox without domain verification), then
# API Keys → Create → paste below.  Real value goes in .env.local.
# Without this key the form still works — it just skips the email.
# ─────────────────────────────────────────────────────────────
RESEND_API_KEY=

# Optional overrides (sensible defaults already in code):
#   Where lead emails land (default hellopromisecity@gmail.com)
# CONTACT_NOTIFY_EMAIL=hellopromisecity@gmail.com
#   Sender (default PromisePD <onboarding@resend.dev>).  Switch to
#   a branded address once promisepd.com is verified in Resend.
# CONTACT_FROM_EMAIL=PromisePD <noreply@promisepd.com>

# ─────────────────────────────────────────────────────────────
# Optional — override the canonical site URL used by metadata,
# sitemap, JSON-LD and OG tags.  Defaults to the Vercel-provided
# URL in production and https://promisepd.com as a final fallback.
# ─────────────────────────────────────────────────────────────
# NEXT_PUBLIC_SITE_URL=https://promisepd.com
